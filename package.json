{
    "name": "hamzacoin",
    "version": "1.0.0",
    "private": true,
    "description": "HamzaCoin (HMZ) — a beginner-friendly ERC20 token built with Hardhat and OpenZeppelin. Educational project for students learning Solidity for the first time.",
    "scripts": {
        "compile": "hardhat compile",
        "node": "hardhat node",
        "deploy:local": "hardhat run scripts/deploy.js --network localhost",
        "transfer:local": "hardhat run scripts/transfer.js --network localhost",
        "balance:local": "hardhat run scripts/check-balance.js --network localhost",
        "deploy:sepolia": "hardhat run scripts/deploy.js --network sepolia",
        "deploy-faucet:sepolia": "hardhat run scripts/deploy-faucet.js --network sepolia",
        "fund-faucet:sepolia": "hardhat run scripts/fund-faucet.js --network sepolia"
    },
    "devDependencies": {
        "@nomicfoundation/hardhat-toolbox": "^5.0.0",
        "@openzeppelin/contracts": "^5.0.2",
        "dotenv": "^17.4.2",
        "hardhat": "^2.22.0"
    }
}
